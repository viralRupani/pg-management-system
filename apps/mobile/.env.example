# The resident app runs on a physical phone that reaches the API over the LAN,
# so this MUST be your Mac's LAN IP (e.g. http://192.168.1.42:4000) — NOT
# localhost/127.0.0.1, which the phone cannot reach. Find it with `ipconfig
# getifaddr en0`. Copy this file to `.env` (gitignored) and set the value.
EXPO_PUBLIC_API_URL=http://192.168.1.x:4000
