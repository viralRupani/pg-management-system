# API server
PORT=4000
NODE_ENV=development

# CORS — admin dashboard + mobile dev origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Postgres — application role (NOBYPASSRLS). Used for all tenant requests.
DATABASE_URL=postgres://app_user:app_user_pw@localhost:5433/pg_management

# Postgres — platform role (BYPASSRLS). Used ONLY by the platform module.
PLATFORM_DATABASE_URL=postgres://platform_user:platform_user_pw@localhost:5433/pg_management

# Postgres — owner/superuser. Used ONLY to run migrations.
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5433/pg_management

# Redis (OTP storage, future BullMQ jobs)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# Resident OTP
OTP_TTL_SECONDS=300
OTP_DEV_LOG=true
# Dev only: force every issued OTP to this fixed 6-digit code (leading zeros
# matter). Leave unset for random codes. Ignored when NODE_ENV=production.
OTP_DEV_FIXED_CODE=999999

# Password reset (manager/owner forgot-password)
PWRESET_TTL_SECONDS=900
# Base URL of the admin web app — reset links point here (.../reset-password?token=).
APP_BASE_URL=http://localhost:3000

# File storage (S3 presigned POST for KYC / payments / complaints / logos)
# STORAGE_DRIVER=local uses an in-process stub (uploads do NOT round-trip — fine
# for tests/CI). Set STORAGE_DRIVER=s3 to use a real bucket; then the four S3_*
# credentials below are REQUIRED (the app refuses to boot without them).
STORAGE_DRIVER=local
# S3_REGION=ap-south-1
# S3_BUCKET=pg-mgmt-dev-uploads
# ACCESS_KEY_ID=AKIA...
# SECRET_ACCESS_KEY=...
# Presigned URL lifetime (seconds) and max upload size (bytes, default 5 MB).
# S3_PRESIGN_TTL_SECONDS=300
# UPLOAD_MAX_BYTES=5242880
# S3-compatible/MinIO only (leave unset for AWS):
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
#
# AWS-side setup (one-time, NOT done by the app):
#   1. Create a PRIVATE bucket (no public ACLs) — all access is via presigned URLs.
#   2. IAM user/key needs s3:PutObject + s3:GetObject on arn:aws:s3:::<bucket>/*.
#   3. Bucket CORS must allow POST + GET from the admin origin
#      (http://localhost:3000) and the Expo app, e.g.:
#      [{"AllowedMethods":["POST","GET"],"AllowedOrigins":["*"],
#        "AllowedHeaders":["*"],"ExposeHeaders":["ETag"]}]
#      (tighten AllowedOrigins for production). Without CORS, browser/app
#      uploads fail with an opaque error.
#
# --- Outbound email (AWS SES) ------------------------------------------------
# Leaving SES_FROM_EMAIL unset = console stub (emails logged, not sent — dev/CI).
# Set SES_FROM_EMAIL to switch to real SES sends (currently: password-reset
# links). SES REUSES the ACCESS_KEY_ID / SECRET_ACCESS_KEY above — the same
# IAM principal just needs ses:SendEmail granted — so STORAGE_DRIVER=s3 is not
# required, but those two creds are. SES is regional: SES_REGION overrides, else
# S3_REGION is used.
# SES_FROM_EMAIL=no-reply@yourpg.com
# SES_REGION=ap-south-1
# MAIL_FROM_NAME is the From display name + the brand name shown in templates.
# MAIL_FROM_NAME=PG Manager
# MAIL_REPLY_TO=support@yourpg.com   # optional; set to a monitored inbox
#
# AWS-side setup (one-time, NOT done by the app):
#   1. Verify SES_FROM_EMAIL as an identity in the SES region.
#   2. Grant the IAM key ses:SendEmail (+ ses:SendRawEmail).
#   3. A new SES account is in SANDBOX: every recipient must also be a verified
#      identity until you request production access — else sends are rejected.
#
# DELIVERABILITY (this is what keeps mail OUT OF SPAM — mostly NOT a code concern):
#   - Verify a DOMAIN identity (not just the address) and enable DKIM signing.
#   - Add the SPF record AWS gives you and a DMARC policy on the From domain.
#   - Use a real domain you control as the From (free-provider From can't be
#     DKIM/DMARC-aligned and will tend to land in spam regardless of template).
#   - Keep bounce/complaint rates low; warm up volume gradually.
#   The HTML+text multipart body and named From here help at the margin, but a
#   polished template from an unauthenticated domain still gets filtered.
