<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <title>{{appName}}</title>
    <!--[if mso]>
      <style type="text/css">
        body, table, td { font-family: Arial, Helvetica, sans-serif !important; }
      </style>
    <![endif]-->
    <style>
      /* Some clients require a class-based reset; inline styles do the heavy lifting. */
      body { margin: 0; padding: 0; width: 100% !important; }
      a { text-decoration: none; }
      @media only screen and (max-width: 600px) {
        .email-card { width: 100% !important; border-radius: 0 !important; }
        .email-pad { padding: 28px 24px !important; }
      }
    </style>
  </head>
  <body style="margin:0; padding:0; background-color:#f1f5f9; color:#0f172a; -webkit-font-smoothing:antialiased;">
    <!-- Preheader: shown as the inbox preview snippet, hidden in the body. -->
    <div style="display:none; max-height:0; overflow:hidden; opacity:0; color:#f1f5f9; font-size:1px; line-height:1px;">
      {{preheader}}
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9;">
      <tr>
        <td align="center" style="padding:32px 16px;">
          <table role="presentation" class="email-card" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px; max-width:600px; background-color:#ffffff; border-radius:14px; overflow:hidden; box-shadow:0 1px 3px rgba(15,23,42,0.08);">
            <!-- Brand header -->
            <tr>
              <td style="background-color:{{brandColor}}; padding:24px 40px;">
                <span style="font-family:Arial,Helvetica,sans-serif; font-size:20px; font-weight:700; letter-spacing:0.2px; color:#ffffff;">{{appName}}</span>
              </td>
            </tr>
            <!-- Content -->
            <tr>
              <td class="email-pad" style="padding:40px; font-family:Arial,Helvetica,sans-serif; font-size:16px; line-height:1.6; color:#334155;">
                {{{body}}}
              </td>
            </tr>
            <!-- Footer -->
            <tr>
              <td style="padding:24px 40px 32px; border-top:1px solid #e2e8f0; font-family:Arial,Helvetica,sans-serif; font-size:12px; line-height:1.6; color:#94a3b8;">
                This is an automated message from {{appName}}. Please do not reply to this email.
                <br />
                &copy; {{year}} {{appName}}. All rights reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
